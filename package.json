{
  "name": "quran-lights",
  "version": "1.1.6",
  "description": "Quran Lights - Track your Quran recitation and memorization progress",
  "main": "electron/main.js",
  "scripts": {
    "test": "cucumber-js tests/features",
    "test:localization": "cucumber-js tests/features/localization.feature",
    "test:report": "cucumber-js tests/features --format html:tests/reports/cucumber-report.html",
    "electron:start": "electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.quranlights.app",
    "productName": "Quran Lights",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      "!public/js/lib/*.js",
      "public/js/lib/jquery.min.js",
      "public/js/lib/bootstrap.min.js",
      "public/js/lib/highcharts*.js",
      "public/js/lib/solid-gauge.js",
      "public/js/lib/exporting.js",
      "public/js/lib/data.js",
      "public/js/lib/drilldown.js",
      "public/js/lib/heatmap.js",
      "public/js/lib/treemap.js",
      "public/js/lib/export-data.js",
      "public/js/lib/accessibility.js",
      "public/js/lib/dark-unica.js",
      "public/js/lib/html2canvas.min.js",
      "public/js/lib/jspdf.umd.min.js",
      "public/js/lib/firebase.js",
      "public/js/lib/material.orange-indigo.min.css",
      "public/js/lib/animate.min.css"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "public/favicon/favicon-32x32.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "public/favicon/favicon-32x32.png",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "public/favicon/favicon-32x32.png",
      "category": "Education"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amr1977/quran_lights_web.git"
  },
  "keywords": ["quran", "islamic", "recitation", "tracker"],
  "author": "Amr Lotfy",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Amr1977/quran_lights_web/issues"
  },
  "homepage": "https://quran-lights.web.app",
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@cucumber/cucumber": "^12.4.0",
    "@cucumber/pretty-formatter": "^2.4.1",
    "@playwright/test": "^1.57.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  }
}
